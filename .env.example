NEXT_PUBLIC_APP_NAME=Eterno Pet
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (defina NEXT_PUBLIC_GOOGLE_ENABLED=true junto com as credenciais p/ exibir o botao)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
PAYMENT_PROVIDER=stripe

EMAIL_PROVIDER=spacemail
EMAIL_FROM=Eterno Pet <contato@eternopet.com.br>
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@eternopet.com.br
SMTP_PASSWORD=
EMAIL_INTERNAL_SECRET=
CRON_SECRET=

# Storage — MinIO (dev local com docker-compose)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET_NAME=eterno-pet-dev
MINIO_PUBLIC_URL=http://localhost:9000

