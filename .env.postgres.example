# Copie para .env.postgres (NUNCA commitar) e preencha os valores

POSTGRES_USER=eternopet
POSTGRES_PASSWORD=troque-por-uma-senha-forte-aleatoria
POSTGRES_DB=eternopet

# Depois do up, sua DATABASE_URL ficara:
# DATABASE_URL=postgresql://eternopet:<senha>@<ip-da-vps>:5432/eternopet
docker compose -f docker-compose.postgres.yml --env-file .env.postgres up -d
