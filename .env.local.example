# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...
PAYMENT_PROVIDER=stripe

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM=Eterno Pet <contato@eternopet.com.br>
RESEND_API_KEY=re_...
# Compatibilidade com configs antigas; EMAIL_FROM tem prioridade quando preenchido.
RESEND_FROM_EMAIL=Eterno Pet <contato@eternopet.com.br>
# Spacemail/SMTP:
# EMAIL_PROVIDER=spacemail
# SMTP_HOST=mail.spacemail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contato@eternopet.com.br
# SMTP_PASSWORD=senha-da-caixa
EMAIL_INTERNAL_SECRET=use-um-segredo-longo
CRON_SECRET=use-outro-segredo-longo

# Storage — MinIO (dev local com docker-compose)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET_NAME=eterno-pet-dev
MINIO_PUBLIC_URL=http://localhost:9000

# Storage — R2 (produção)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=eterno-pet-prd
# R2_PUBLIC_URL=https://<account-id>.r2.cloudflarestorage.com/<bucket>
